{
  "name": "debate-moderator",
  "description": "Moderates 3 rounds of structured blind debate between council agents, creating debate_messages records.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "visibility": "POD",
  "output_schema": {
    "type": "object",
    "properties": {
      "session_id": { "type": "string" },
      "vote_breakdown": { "type": "object" },
      "reasoning_trail": { "type": "array" },
      "final_positions": { "type": "array" }
    },
    "required": ["session_id", "vote_breakdown", "reasoning_trail", "final_positions"]
  },
  "permissions": {
    "grants": [
      { "resource_type": "function", "resource_name": "write_db_record", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "function", "resource_name": "update_db_record", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "datastore_table", "resource_name": "debate_rounds", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "debate_messages", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] }
    ]
  }
}
