{
  "name": "debate-moderator",
  "description": "Moderates live active-challenge debate by sending targeted prompts to separate council-agent conversations and persisting every response to debate_messages.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "visibility": "POD",
  "output_schema": {
    "type": "object",
    "properties": {
      "session_id": { "type": "string" },
      "vote_breakdown": {
        "type": "object",
        "properties": {
          "for": { "type": "array", "items": { "type": "string" } },
          "against": { "type": "array", "items": { "type": "string" } },
          "abstain": { "type": "array", "items": { "type": "string" } },
          "reframe": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["for", "against", "abstain", "reframe"]
      },
      "reasoning_trail": { "type": "array", "items": { "type": "object" } },
      "final_positions": { "type": "array", "items": { "type": "object" } }
    },
    "required": ["session_id", "vote_breakdown", "reasoning_trail", "final_positions"]
  },
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "debate_sessions", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "debate_rounds", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "debate_messages", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "pre_mortems", "permission_ids": ["datastore.table.read", "datastore.record.read"] }
    ]
  }
}