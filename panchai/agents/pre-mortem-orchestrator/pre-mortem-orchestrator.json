{
  "name": "pre-mortem-orchestrator",
  "description": "Runs the pre-mortem phase: calls registry_lookup, creates debate_rounds and pre_mortems records for each council agent.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "visibility": "POD",
  "output_schema": {
    "type": "object",
    "properties": {
      "session_id": { "type": "string" },
      "round_id": { "type": "string" },
      "agent_ids": { "type": "array", "items": { "type": "string" } },
      "pre_mortems": { "type": "array", "items": { "type": "object" } },
      "has_critical": { "type": "boolean" }
    },
    "required": ["session_id", "round_id", "agent_ids", "pre_mortems", "has_critical"]
  },
  "permissions": {
    "grants": [
      { "resource_type": "function", "resource_name": "registry_lookup", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "function", "resource_name": "run_council", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "function", "resource_name": "batch_write", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "datastore_table", "resource_name": "agent_catalog", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "debate_rounds", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "pre_mortems", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] }
    ]
  }
}
