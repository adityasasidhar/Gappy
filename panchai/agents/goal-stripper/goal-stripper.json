{
  "name": "goal-stripper",
  "description": "Strips the user's goal from raw task input using the goal_strip function, then creates the debate_sessions record.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "visibility": "POD",
  "output_schema": {
    "type": "object",
    "properties": {
      "session_id": { "type": "string" },
      "stripped_task": { "type": "string" },
      "user_goal": { "type": "string" },
      "stakes_level": { "type": "string", "enum": ["STANDARD", "HIGH"] },
      "council_size": { "type": "integer" }
    },
    "required": ["session_id", "stripped_task", "user_goal", "stakes_level", "council_size"]
  },
  "permissions": {
    "grants": [
      { "resource_type": "function", "resource_name": "goal_strip", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "function", "resource_name": "write_db_record", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "datastore_table", "resource_name": "debate_sessions", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] }
    ]
  }
}
