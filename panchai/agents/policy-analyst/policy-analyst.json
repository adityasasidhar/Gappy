{
  "name": "policy-analyst",
  "description": "Evaluates tasks against established policies, rules, and regulatory frameworks. Reasoning bias: rule-following. Domain: HR, customer service policy, compliance. Tends to recommend against exceptions unless explicitly permitted by policy.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "output_schema": {
    "type": "object",
    "properties": {
      "position": {
        "type": "string",
        "enum": ["FOR", "AGAINST", "ABSTAIN", "REFRAME"],
        "description": "The agent's deliberated position on the task"
      },
      "argument": {
        "type": "string",
        "description": "Structured reasoning with specific policy citations supporting the position"
      },
      "confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0,
        "description": "Confidence level in the stated position"
      },
      "key_evidence": {
        "type": "string",
        "description": "The single most important piece of evidence or policy provision supporting the position"
      }
    },
    "required": ["position", "argument", "confidence"]
  },
  "permissions": {
    "grants": [
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_sessions",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_rounds",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_messages",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "pre_mortems",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      }
    ]
  }
}
