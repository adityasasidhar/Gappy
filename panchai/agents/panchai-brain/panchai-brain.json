{
  "name": "panchai-brain",
  "description": "Processes the HITL decision and finalizes the session. Updates hitl_queue with the decision and debate_sessions with the final status.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "output_schema": {
    "type": "object",
    "properties": {
      "session_id": { "type": "string" },
      "verdict": { "type": "string", "enum": ["APPROVED", "REJECTED", "ESCALATED", "REFRAMED"] },
      "confidence_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
      "hitl_required": { "type": "boolean" },
      "summary": { "type": "string" }
    },
    "required": ["session_id", "verdict", "confidence_score", "hitl_required", "summary"]
  },
  "permissions": {
    "grants": [
      { "resource_type": "function", "resource_name": "write_db_record", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "function", "resource_name": "update_db_record", "permission_ids": ["function.read", "function.execute"] },
      { "resource_type": "datastore_table", "resource_name": "hitl_queue", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "debate_sessions", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] }
    ]
  }
}
