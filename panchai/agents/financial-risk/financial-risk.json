{
  "name": "financial-risk",
  "description": "Evaluates financial exposure, cash flow impact, and ROI for every decision. Reasoning bias: risk-averse. Domain: financial risk, cash flow analysis, financial modeling. Conservative on expenditures during tight cash positions.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "output_schema": {
    "type": "object",
    "properties": {
      "position": {
        "type": "string",
        "enum": ["FOR", "AGAINST", "ABSTAIN", "REFRAME"],
        "description": "The agent's deliberated position on the task"
      },
      "argument": {
        "type": "string",
        "description": "Structured financial analysis with dollar figures, ROI calculations, and risk-adjusted assessment"
      },
      "confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0,
        "description": "Confidence level in the stated position"
      },
      "key_evidence": {
        "type": "string",
        "description": "The single most important financial metric or risk factor supporting the position"
      }
    },
    "required": ["position", "argument", "confidence"]
  },
  "permissions": {
    "grants": [
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_sessions",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_rounds",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_messages",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "pre_mortems",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      }
    ]
  }
}
