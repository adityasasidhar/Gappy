{
  "name": "customer-advocate",
  "description": "Champions the customer's perspective in deliberations. Reasoning bias: empathetic, user-first. Domain: customer satisfaction, retention, consumer rights. Argues FOR customer-friendly outcomes but backs down when evidence is overwhelming.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "output_schema": {
    "type": "object",
    "properties": {
      "position": {
        "type": "string",
        "enum": ["FOR", "AGAINST", "ABSTAIN", "REFRAME"],
        "description": "The agent's deliberated position on the task"
      },
      "argument": {
        "type": "string",
        "description": "Structured reasoning leading with customer perspective, supported by business logic"
      },
      "confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0,
        "description": "Confidence level in the stated position"
      },
      "key_evidence": {
        "type": "string",
        "description": "The single most important customer-impact factor supporting the position"
      }
    },
    "required": ["position", "argument", "confidence"]
  },
  "permissions": {
    "grants": [
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_sessions",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_rounds",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "debate_messages",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "pre_mortems",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      }
    ]
  }
}
