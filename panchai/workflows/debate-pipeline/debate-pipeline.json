{
  "name": "debate-pipeline",
  "description": "PANCHAI fast deliberation: fill form -> auto-creates session -> 5-agent council (parallel) -> verdict -> done. ~3s.",
  "start": {
    "type": "MANUAL",
    "config": null
  },
  "nodes": [
    {
      "id": "input_form",
      "type": "FORM",
      "label": "Enter Task",
      "config": {
        "input_schema": {
          "type": "object",
          "required": ["task_input"],
          "properties": {
            "task_input": { "type": "string", "title": "Task", "description": "The task or question to deliberate" },
            "task_context": { "type": "string", "title": "Context (JSON)", "description": "Optional JSON context (e.g. customer info)" },
            "client_id": { "type": "string", "title": "Client ID", "description": "e.g. yesmadam, binocs" },
            "stakes_level": { "type": "string", "title": "Stakes Level", "enum": ["STANDARD", "HIGH"] }
          }
        }
      }
    },
    {
      "id": "goal_stripper",
      "type": "FUNCTION",
      "label": "Goal Stripper",
      "config": {
        "function_name": "goal_strip",
        "input_mapping": {
          "task_input": { "type": "expression", "value": "input_form.task_input" },
          "task_context": { "type": "expression", "value": "input_form.task_context" },
          "client_id": { "type": "expression", "value": "input_form.client_id" },
          "stakes_level": { "type": "expression", "value": "input_form.stakes_level" }
        }
      }
    },
    {
      "id": "deliberation",
      "type": "FUNCTION",
      "label": "Fast Deliberation",
      "config": {
        "function_name": "fast_pipeline",
        "input_mapping": {
          "session_id": { "type": "expression", "value": "goal_stripper.session_id" },
          "stripped_task": { "type": "expression", "value": "goal_stripper.stripped_task" },
          "user_goal": { "type": "expression", "value": "goal_stripper.user_goal" },
          "client_id": { "type": "expression", "value": "goal_stripper.client_id" },
          "stakes_level": { "type": "expression", "value": "goal_stripper.stakes_level" },
          "council_size": { "type": "expression", "value": "goal_stripper.council_size" }
        }
      }
    },
    {
      "id": "check_hitl",
      "type": "DECISION",
      "label": "HITL Required?",
      "config": {
        "rules": [
          { "condition": "deliberation.verdict.hitl_required == true", "next_node_id": "hitl_approval" }
        ]
      }
    },
    {
      "id": "hitl_approval",
      "type": "FORM",
      "label": "Human-in-the-Loop Approval",
      "config": {
        "input_schema": {
          "type": "object",
          "properties": {
            "decision": { "type": "string", "enum": ["approve", "reject", "send_back"] },
            "decision_reason": { "type": "string" }
          },
          "required": ["decision", "decision_reason"]
        }
      }
    },
    {
      "id": "process_hitl",
      "type": "AGENT",
      "label": "Process HITL",
      "config": {
        "agent_name": "panchai-brain",
        "input_mapping": {
          "session_id": { "type": "expression", "value": "deliberation.session_id" },
          "decision": { "type": "expression", "value": "hitl_approval.decision" },
          "decision_reason": { "type": "expression", "value": "hitl_approval.decision_reason" },
          "verdict": { "type": "expression", "value": "deliberation.verdict.verdict" },
          "confidence_score": { "type": "expression", "value": "deliberation.verdict.confidence_score" }
        }
      }
    },
    { "id": "done", "type": "END", "label": "Done" }
  ],
  "edges": [
    { "id": "e0", "source": "input_form", "target": "goal_stripper" },
    { "id": "e1", "source": "goal_stripper", "target": "deliberation" },
    { "id": "e2", "source": "deliberation", "target": "check_hitl" },
    { "id": "e3", "source": "check_hitl", "target": "done" },
    { "id": "e4", "source": "check_hitl", "target": "hitl_approval" },
    { "id": "e5", "source": "hitl_approval", "target": "process_hitl" },
    { "id": "e6", "source": "process_hitl", "target": "done" }
  ]
}
