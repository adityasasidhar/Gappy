{
  "name": "verdicts",
  "description": "Final structured verdict per session. Contains vote tallies, conflict reports, reasoning trails, and HITL escalation flags.",
  "primary_key_column": "id",
  "enable_rls": false,
  "columns": [
    { "name": "session_id", "type": "TEXT", "required": true,
      "description": "FK to debate_sessions" },
    { "name": "verdict", "type": "ENUM", "required": true,
      "options": ["APPROVED", "REJECTED", "ESCALATED", "REFRAMED"] },
    { "name": "confidence_score", "type": "FLOAT", "required": true,
      "description": "0.0 to 1.0 confidence in the verdict" },
    { "name": "council_vote_for", "type": "TEXT",
      "description": "JSON array of agent IDs who voted FOR" },
    { "name": "council_vote_against", "type": "TEXT",
      "description": "JSON array of agent IDs who voted AGAINST" },
    { "name": "council_vote_abstain", "type": "TEXT",
      "description": "JSON array of agent IDs who voted ABSTAIN" },
    { "name": "conflict_report", "type": "TEXT",
      "description": "JSON: {user_goal, council_finding, divergence_severity}" },
    { "name": "reasoning_trail", "type": "TEXT",
      "description": "JSON array of round-by-round arguments" },
    { "name": "pre_mortem_summary", "type": "TEXT",
      "description": "JSON array of pre-mortem entries" },
    { "name": "hitl_required", "type": "BOOLEAN", "default": false,
      "description": "Whether human-in-the-loop review is required" },
    { "name": "hitl_reason", "type": "TEXT",
      "description": "Why HITL was triggered" },
    { "name": "recommended_action", "type": "TEXT",
      "description": "The council's recommended next step" },
    { "name": "minority_dissent", "type": "TEXT",
      "description": "Dissenting agent's full argument" }
  ],
  "config": {}
}
