{
  "name": "debate_rounds",
  "description": "One row per round in a debate. Tracks round progression and Brain's targeted challenge prompts.",
  "primary_key_column": "id",
  "enable_rls": false,
  "columns": [
    { "name": "session_id", "type": "TEXT", "required": true,
      "description": "FK to debate_sessions" },
    { "name": "round_number", "type": "INT", "required": true },
    { "name": "round_type", "type": "ENUM", "required": true,
      "options": ["pre_mortem", "debate", "bonus"] },
    { "name": "status", "type": "ENUM", "required": true, "default": "pending",
      "options": ["pending", "active", "complete"] },
    { "name": "challenge_prompt", "type": "TEXT",
      "description": "Brain's targeted challenge for this round" }
  ],
  "config": {}
}
