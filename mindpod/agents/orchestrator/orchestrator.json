{
  "name": "orchestrator",
  "description": "The main agent users talk to. Understands their goal, inspects what files/data are in the pod, chooses the right mode (learn/research/analyze), delegates to the specialist agent, and writes a session record.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD", "WEB_SEARCH", "USER_INTERACTION"],
  "output_schema": {
    "type": "object",
    "properties": {
      "session_id":  { "type": "string" },
      "mode":        { "type": "string", "enum": ["learn", "research", "analyze", "multi"] },
      "summary":     { "type": "string" },
      "next_agents": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["session_id", "mode", "summary"]
  },
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "sessions",
        "permission_ids": ["datastore.table.read", "datastore.record.read",
                           "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "insights",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "study_items",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "folder", "resource_name": "/knowledge",
        "permission_ids": ["folder.read"] },
      { "resource_type": "folder", "resource_name": "/data",
        "permission_ids": ["folder.read"] },
      { "resource_type": "agent", "resource_name": "study-agent",
        "permission_ids": ["agent.execute"] },
      { "resource_type": "agent", "resource_name": "research-agent",
        "permission_ids": ["agent.execute"] },
      { "resource_type": "agent", "resource_name": "data-agent",
        "permission_ids": ["agent.execute"] }
    ]
  }
}
