{
  "name": "data-agent",
  "description": "Data analysis specialist. Reads CSVs from /data using the CLI sandbox, runs EDA, surfaces patterns, anomalies, and answers analytical questions. Writes structured insights to the insights table.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD", "WORKSPACE_CLI"],
  "output_schema": {
    "type": "object",
    "properties": {
      "session_id":       { "type": "string" },
      "insights_written": { "type": "integer" },
      "datasets_analyzed": { "type": "array", "items": { "type": "string" } },
      "key_findings":     { "type": "array", "items": { "type": "string" } },
      "analysis_summary": { "type": "string" }
    },
    "required": ["session_id", "insights_written", "datasets_analyzed", "analysis_summary"]
  },
  "permissions": {
    "grants": [
      { "resource_type": "folder", "resource_name": "/data",
        "permission_ids": ["folder.read"] },
      { "resource_type": "folder", "resource_name": "/knowledge",
        "permission_ids": ["folder.read"] },
      { "resource_type": "datastore_table", "resource_name": "sessions",
        "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "insights",
        "permission_ids": ["datastore.table.read", "datastore.record.read",
                           "datastore.record.write"] }
    ]
  }
}
