{
  "name": "study_items",
  "description": "Learning artifacts generated by the study agent — flashcards, quiz questions, weak area flags, study notes.",
  "primary_key_column": "id",
  "enable_rls": false,
  "columns": [
    { "name": "session_id",  "type": "TEXT",  "required": true },
    { "name": "item_type",   "type": "ENUM",  "required": true,
      "options": ["flashcard", "quiz_question", "weak_area", "study_note", "practice_problem"] },
    { "name": "topic",       "type": "TEXT",  "required": true },
    { "name": "question",    "type": "TEXT" },
    { "name": "answer",      "type": "TEXT" },
    { "name": "difficulty",  "type": "ENUM",  "default": "medium",
      "options": ["easy", "medium", "hard"] },
    { "name": "source_page", "type": "TEXT",
      "description": "e.g. '/knowledge/notes.pdf pages 3-5'" }
  ],
  "config": {}
}
